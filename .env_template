# Embrava API Credentials
EMBRAVA_ORGANIZATION_ID=your-organization-id
EMBRAVA_SECRET_KEY=your-secret-key
EMBRAVA_API_BASE_URL=https://eusfuncapp01.azurewebsites.net/api

# Webhook Configuration
# Generate a UUID for webhook secret: uuidgen
WEBHOOK_SECRET=your-webhook-secret-uuid
# Set this to your ngrok URL when running: export WEBHOOK_BASE_URL=https://xxxx.ngrok-free.app
# In Vercel: set to https://<project>.vercel.app for Production scope only; leave unset for Preview.
WEBHOOK_BASE_URL=

# MongoDB
# Local dev: mongodb://localhost:27017/embrava-sensors
# Production (Vercel): mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/embrava-sensors
MONGODB_URI=mongodb://localhost:27017/embrava-sensors

# Admin endpoint (POST /api/admin/register-webhooks) bearer token
# Generate: openssl rand -hex 32
ADMIN_TOKEN=your-admin-token

# HTTP Basic Auth gate for the web UI (leave blank in local dev to disable)
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
