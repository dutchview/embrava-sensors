# Embrava API Credentials
EMBRAVA_ORGANIZATION_ID=your-organization-id
EMBRAVA_SECRET_KEY=your-secret-key
EMBRAVA_API_BASE_URL=https://eusfuncapp01.azurewebsites.net/api

# Webhook Configuration
# Generate a UUID for webhook secret: uuidgen
WEBHOOK_SECRET=your-webhook-secret-uuid
# Set this to your ngrok URL when running: export WEBHOOK_BASE_URL=https://xxxx.ngrok-free.app
WEBHOOK_BASE_URL=

# MongoDB
MONGODB_URI=mongodb://localhost:27017/embrava-sensors

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
